# .functions

function dtm() {
    for arg in "$@"; do
        echo "Modifying $arg"
        devtool modify "$arg"
    done
}

function gsa() {
    local reset="\e[0m" sep=" · "
    for dir in */; do
        if [ -d "$dir/.git" ]; then
            local branch counts behind ahead state
            branch="$(git -C "$dir" rev-parse --abbrev-ref HEAD 2>/dev/null)"
            if counts="$(git -C "$dir" rev-list --left-right --count '@{upstream}...HEAD' 2>/dev/null)"; then
                read -r behind ahead <<< "$counts"
                state=""
                [ "$ahead" -gt 0 ] && state="↑${ahead}"
                [ "$behind" -gt 0 ] && state="${state}↓${behind}"
                state="${state:-up to date}"
            else
                state="no upstream"
            fi
            echo -e "${PRIMARY_COLOR}${dir%/}${reset}${sep}${SECONDARY_COLOR}${branch}${reset}${sep}${TERTIARY_COLOR}${state}${reset}"
            git -C "$dir" status -s
        fi
    done
}

function gpa() {
    local reset="\e[0m" sep=" · " max=8 tmp dirs=() d first log
    local osc='\e]8;;' st='\e\\'
    tmp="$(mktemp -d -t gpa.XXXXXX)"
    for d in */; do
        [ -d "$d/.git" ] && dirs+=("${d%/}")
    done
    (
        for d in "${dirs[@]}"; do
            git -C "$d" pull --ff-only >"$tmp/$d.log" 2>&1 &
            while [ "$(jobs -rp | wc -l)" -ge "$max" ]; do wait -n; done
        done
        wait
    )
    for d in "${dirs[@]}"; do
        first="$(head -1 "$tmp/$d.log")"
        if [ "$(wc -l < "$tmp/$d.log")" -le 1 ]; then
            echo -e "${PRIMARY_COLOR}${d}${reset}${sep}${SECONDARY_COLOR}${first}${reset}"
            rm -f "$tmp/$d.log"
        else
            log="${tmp}/${d}.log"
            echo -e "${PRIMARY_COLOR}${d}${reset}${sep}${SECONDARY_COLOR}${first}${reset}${sep}${TERTIARY_COLOR}${osc}file://${HOSTNAME}${log}${st}${log}${osc}${st}${reset}"
        fi
    done
    rmdir "$tmp" 2>/dev/null
}

function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	command yazi "$@" --cwd-file="$tmp"
	IFS= read -r -d '' cwd < "$tmp"
	[ "$cwd" != "$PWD" ] && [ -d "$cwd" ] && builtin cd -- "$cwd"
	command rm -f -- "$tmp"
}
