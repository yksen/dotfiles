#!/bin/bash

# TODO: Try to set it before starting X server
WALLPAPER_DIR=$( cd -- "$( dirname -- "$(readlink -f "${BASH_SOURCE[0]}")" )" &> /dev/null && pwd )
feh --no-fehbg --bg-scale "$WALLPAPER_DIR/../wallpaper.png"

# Serve the dark theme to GTK/Qt apps over XSETTINGS for the whole session
if command -v xsettingsd &> /dev/null && ! pgrep -x xsettingsd > /dev/null; then
    xsettingsd &
fi
